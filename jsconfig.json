{
  // Reference: https://www.typescriptlang.org/tsconfig (jsconfig.json shares
  // the same compilerOptions schema). This project has no bundler and no
  // dependencies (see README "Non-goals": no framework, no build tool) — every
  // script is a plain global <script> with no import/export, so "module" is
  // intentionally left unset (nothing to configure), and there is no
  // node_modules to bound with maxNodeModuleJsDepth.
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "allowJs": true,
    "checkJs": true,
    "strict": true
  },
  "exclude": ["node_modules"]
}
